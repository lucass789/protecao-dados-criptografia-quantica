# =============================================================================
# VARIÁVEIS DE AMBIENTE — CONFIGURAÇÃO DO EXPERIMENTO BB84 EM HARDWARE REAL IBM
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com tokens ou CRNs reais.
# =============================================================================

# Token de autenticação IBM Quantum Platform
# Obtenha em: https://quantum.ibm.com/ > Account > API token
IBM_QUANTUM_TOKEN=SEU_TOKEN_AQUI

# CRN da instância IBM Quantum (identificador único do seu acesso)
# Obtenha em: IBM Quantum > Instances > sua instância > copie o CRN
IBM_QUANTUM_INSTANCE=SEU_CRN_AQUI

# Backend preferido (opcional). Se vazio, o script seleciona automaticamente
# o backend com menor fila de trabalhos disponível.
# Exemplo: ibm_marrakesh, ibm_fez, ibmq_qasm_simulator
IBM_BACKEND=

# Número de qubits transmitidos por execução BB84
# Padrão: 8 (v1) / 16 (v2)
N_QUBITS=16

# Número de shots (medições) por circuito
# Padrão: 1024
SHOTS=1024

# Número de repetições do experimento por cenário (sem Eva / com Eva)
# Padrão: 3
REPETICOES=3
